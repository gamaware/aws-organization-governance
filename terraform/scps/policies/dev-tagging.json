{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreateWithoutTeamTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateInternetGateway",
        "ec2:CreateNatGateway",
        "ec2:CreateRouteTable",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Team": "true"
        },
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/*AWSReservedSSO_*",
            "arn:aws:iam::*:role/Organization*",
            "arn:aws:iam::*:role/cleanup-*",
            "arn:aws:iam::*:role/*-cluster-*",
            "arn:aws:iam::*:role/*-eks-node-group-*"
          ]
        }
      }
    },
    {
      "Sid": "DenyCreateWithoutNameTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateInternetGateway",
        "ec2:CreateNatGateway",
        "ec2:CreateRouteTable",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Name": "true"
        },
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/*AWSReservedSSO_*",
            "arn:aws:iam::*:role/Organization*",
            "arn:aws:iam::*:role/cleanup-*",
            "arn:aws:iam::*:role/*-cluster-*",
            "arn:aws:iam::*:role/*-eks-node-group-*"
          ]
        }
      }
    },
    {
      "Sid": "DenyInvalidTeamTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateInternetGateway",
        "ec2:CreateNatGateway",
        "ec2:CreateRouteTable",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestTag/Team": [
            "team-1",
            "team-2",
            "team-3",
            "team-4",
            "team-5",
            "team-6",
            "team-7"
          ]
        },
        "Null": {
          "aws:RequestTag/Team": "false"
        },
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/*AWSReservedSSO_*",
            "arn:aws:iam::*:role/Organization*",
            "arn:aws:iam::*:role/cleanup-*",
            "arn:aws:iam::*:role/*-cluster-*",
            "arn:aws:iam::*:role/*-eks-node-group-*"
          ]
        }
      }
    },
    {
      "Sid": "DenyInvalidNameTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "ec2:CreateInternetGateway",
        "ec2:CreateNatGateway",
        "ec2:CreateRouteTable",
        "ec2:AllocateAddress",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:RequestTag/Name": "*@iteso.mx"
        },
        "Null": {
          "aws:RequestTag/Name": "false"
        },
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/*AWSReservedSSO_*",
            "arn:aws:iam::*:role/Organization*",
            "arn:aws:iam::*:role/cleanup-*",
            "arn:aws:iam::*:role/*-cluster-*",
            "arn:aws:iam::*:role/*-eks-node-group-*"
          ]
        }
      }
    }
  ]
}
