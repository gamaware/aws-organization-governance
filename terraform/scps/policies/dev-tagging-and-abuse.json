{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyCreateWithoutTeamTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack",
        "cloudfront:CreateDistribution"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Team": "true"
        }
      }
    },
    {
      "Sid": "DenyCreateWithoutNameTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack",
        "cloudfront:CreateDistribution"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/Name": "true"
        }
      }
    },
    {
      "Sid": "DenyInvalidTeamTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack",
        "cloudfront:CreateDistribution"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:RequestTag/Team": [
            "team-1",
            "team-2",
            "team-3",
            "team-4",
            "team-5",
            "team-6",
            "team-7"
          ]
        },
        "Null": {
          "aws:RequestTag/Team": "false"
        }
      }
    },
    {
      "Sid": "DenyInvalidNameTag",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVpc",
        "ec2:CreateSubnet",
        "ec2:CreateSecurityGroup",
        "rds:CreateDBInstance",
        "rds:CreateDBCluster",
        "lambda:CreateFunction",
        "s3:PutBucketTagging",
        "dynamodb:CreateTable",
        "sqs:CreateQueue",
        "sns:CreateTopic",
        "ecs:CreateCluster",
        "ecs:CreateService",
        "ecr:CreateRepository",
        "elasticache:CreateCacheCluster",
        "elasticache:CreateReplicationGroup",
        "elasticloadbalancing:CreateLoadBalancer",
        "elasticloadbalancing:CreateTargetGroup",
        "events:PutRule",
        "cognito-idp:CreateUserPool",
        "states:CreateStateMachine",
        "secretsmanager:CreateSecret",
        "cloudformation:CreateStack",
        "cloudfront:CreateDistribution"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "aws:RequestTag/Name": "*@iteso.mx"
        },
        "Null": {
          "aws:RequestTag/Name": "false"
        }
      }
    },
    {
      "Sid": "DenyGPUAndMetalInstances",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:StartInstances"
      ],
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringLike": {
          "ec2:InstanceType": [
            "p*",
            "g*",
            "inf*",
            "trn*",
            "dl*",
            "*.metal",
            "*.metal-*"
          ]
        }
      }
    },
    {
      "Sid": "DenySageMakerExpensiveInstances",
      "Effect": "Deny",
      "Action": [
        "sagemaker:CreateNotebookInstance",
        "sagemaker:CreateEndpointConfig",
        "sagemaker:CreateTrainingJob"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "sagemaker:InstanceType": [
            "ml.t2.*",
            "ml.t3.*"
          ]
        }
      }
    },
    {
      "Sid": "DenyAbusableServices",
      "Effect": "Deny",
      "Action": [
        "lightsail:*",
        "gamelift:*",
        "aws-marketplace:Subscribe",
        "aws-marketplace:AcceptAgreementApprovalRequest"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyLargeEBSVolumes",
      "Effect": "Deny",
      "Action": [
        "ec2:CreateVolume",
        "ec2:RunInstances"
      ],
      "Resource": "arn:aws:ec2:*:*:volume/*",
      "Condition": {
        "NumericGreaterThan": {
          "ec2:VolumeSize": "100"
        }
      }
    },
    {
      "Sid": "DenyPublicDataExposure",
      "Effect": "Deny",
      "Action": [
        "s3:DeletePublicAccessBlock",
        "rds:ModifyDBSnapshotAttribute",
        "rds:ModifyDBClusterSnapshotAttribute",
        "ec2:ModifySnapshotAttribute"
      ],
      "Resource": "*"
    }
  ]
}
